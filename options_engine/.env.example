# Copy to .env and fill in. Then: set -a; source .env; set +a
# This file (.env) is gitignored — never commit your real tokens.

# Robinhood agentic account number (kept out of the repo; used in order tickets).
ROBINHOOD_ACCOUNT=

# Tradier market-data token (production endpoint for real Greeks/IV).
TRADIER_TOKEN=
# Optional: only needed if you later add account/position reads.
TRADIER_ACCOUNT_ID=
# Leave default unless you intentionally want delayed sandbox data:
# TRADIER_BASE_URL=https://api.tradier.com/v1

# ---- Notifications (assistant layer) ----
# Telegram (primary). @BotFather -> /newbot for the token; getUpdates for chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Twilio SMS (fallback) — reuse your equity bot's account.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
ALERT_PHONE=
# Email (last resort) — use a relay (SendGrid) since DO blocks direct SMTP.
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_TO=
# Dashboard port (optional)
DASHBOARD_PORT=8080
